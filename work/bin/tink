#!/bin/bash
gr () {
    local dir=$(git rev-parse --show-toplevel);
    if [[ -z $dir ]]; then
        echo 'Failed to find directory' 1>&2;
        return 2;
    fi;
    cd "$dir"
}

gr &&

if [[ ! -e artisan ]]; then
    for dir in \
        ../g2p_api \
        api \
        ; do

        if [[ -d $dir ]]; then
            printf 'Switching directory to %s ...\n' "$dir" >&2
            cd "$dir"
            break
        fi
    done
fi &&
if [[ ! -e artisan ]]; then
    exit 1
fi

exec art tink
