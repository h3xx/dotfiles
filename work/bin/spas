#!/usr/bin/env bash

HELP_MESSAGE() {
	local EXIT_CODE="${1:-0}"
	cat <<EOF
Usage: $(basename -- "$0") [OPTIONS] [--] MODE
Subpull and sync at G2Planet.

  -h		Show this help message.
  -m		Reload menus after sync.
  -M		Run migration scripts.
  -d		Rebuild database after sync.
  -D		Rebuild database before sync IF NEEDED.
  --		Terminate options list.

Copyright (C) 2015-2017 Dan Church.
License GPLv3+: GNU GPL version 3 or later (http://gnu.org/licenses/gpl.html).
This is free software: you are free to change and redistribute it. There is NO
WARRANTY, to the extent permitted by law.
EOF
	exit "$EXIT_CODE"
}

RELOAD_MENUS=0
REBUILD_DB=0
REBUILD_DB_SOFT=0
MIGRATION=0

while getopts 'hmdDM' flag; do
	case "$flag" in
		'h')
			HELP_MESSAGE 0
			;;
		'm')
			RELOAD_MENUS=1
			;;
		'M')
			MIGRATION=1
			;;
		'd')
			REBUILD_DB=1
			;;
		'D')
			REBUILD_DB_SOFT=1
			;;
		*)
			HELP_MESSAGE 1
			;;
	esac
done

shift "$((OPTIND-1))"

MODE=''
if [[ $# -eq 0 ]]; then
	git_branch=$(git rev-parse --abbrev-ref HEAD)
	case "$git_branch" in
		'demo')
			MODE=demo
			;;
		'master')
			MODE=sales
			;;
	esac
else
	MODE=$1
fi

if [[ -z $MODE ]]; then
	HELP_MESSAGE 1
fi

echo "*** subpull and sync ***"
echo "mode: $MODE"

if [[ -f GNUmakefile ]]; then
    MAKE="make CONF=$MODE"
else
    MAKE="bmake $MODE"
fi

git pull &&
git subpull &&
sudo $MAKE pause || exit

# if schemacheck fails, we have to rebuild the database BEFORE syncing
if [[ $REBUILD_DB -ne 0 || $REBUILD_DB_SOFT -ne 0 ]] && ! sudo $MAKE schemacheck; then
    sudo $MAKE reload || exit
    REBUILD_DB=0
fi

echo y |sudo $MAKE sync

err="$?"
if [[ $err -ne 0 ]]; then
	exit "$err"
fi

if [[ $REBUILD_DB -ne 0 ]]; then
	sudo $MAKE reload || exit
fi

if [[ $MIGRATION -ne 0 ]]; then
	for mscript in \
		migration-2.[1-9].sh \
	; do
		if [[ -f php/eclib/data/$mscript ]]; then
			(set -x ; cd php/eclib/data && ./$mscript "$MODE") || exit
		fi
		if [[ -f data/$mscript ]]; then
			(set -x ; cd data && ./$mscript "$MODE") || exit
		fi
	done
fi

if [[ $RELOAD_MENUS -ne 0 ]]; then
	(cd data && ./reload_menus.sh "$MODE") || exit
fi

    sudo $MAKE unpause
err="$?"

exit "$err"
