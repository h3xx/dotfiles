#!/bin/bash

HELP_MESSAGE() {
	local EXIT_CODE="${1:-0}"
	cat <<EOF
Usage: $(basename -- "$0") [OPTIONS] FILE...
Run coverage testing.

  -h		Show this help message.
  -p		Permissive coverage.
  -R		Stop on risky.
  -t		Show tap tracing instead.

Copyright (C) 2016 Dan Church.
License GPLv3+: GNU GPL version 3 or later (http://gnu.org/licenses/gpl.html).
This is free software: you are free to change and redistribute it. There is NO
WARRANTY, to the extent permitted by law.
EOF
	exit "$EXIT_CODE"
}

MODE='html'
STOP_ON_RISKY=0
PERMISSIVE=0

while getopts 'hpRt' flag; do
	case "$flag" in
		'p')
			PERMISSIVE=1
			;;
		'R')
			STOP_ON_RISKY=1
			;;
		't')
			MODE='tap'
			;;
		'h')
			HELP_MESSAGE 0
			;;
		*)
			HELP_MESSAGE 1
			;;
	esac
done

shift "$((OPTIND-1))"

HTML_OUT_DIR='cov'
# no need to find phpunit.xml - phpunit should already be a smart wrapper
PHPUNIT=phpunit

PHPUNIT_ARGS=()

if [[ $PERMISSIVE -eq 0 ]]; then
	PHPUNIT_ARGS+=(--strict-coverage)
fi

if [[ $STOP_ON_RISKY -ne 0 ]]; then
	PHPUNIT_ARGS+=(--stop-on-risky)
fi

if [[ $MODE = 'html' ]]; then
	PHPUNIT_ARGS+=(
		--coverage-html "$HTML_OUT_DIR"
	)
elif [[ $MODE = 'tap' ]]; then
	PHPUNIT_ARGS+=(
		--coverage-text
		--tap
	)
fi

set -x
"$PHPUNIT" "${PHPUNIT_ARGS[@]}" "$@"
set +x


if [[ $MODE = 'html' ]]; then
    HTML_TO_OPEN=(
    )

    if [[ -f "$HTML_OUT_DIR/index.html" ]]; then
        HTML_TO_OPEN+=(
            "$HTML_OUT_DIR/index.html"
        )
    fi

    if [[ $# -gt 0 ]]; then
        # single test was run
        test_run="$(
            for fn in \
                "$1" \
                "$1.php" \
                ; do
                if [[ -f $fn ]]; then
                    echo "$fn"
                    break
                fi
            done
        )"
        if [[ -n $test_run ]]; then
            covers_classes=(
                $(
                    sed -ne 's,^.*@covers \\\?\([^:]*\).*$,\1,p' "$test_run" |
                    sort -u
                )
            )
            echo "Classes covered: ${covers_classes[*]}" >&2
            HTML_TO_OPEN=()
            for class in "${covers_classes[@]}"; do
                HTML_TO_OPEN+=(
                    "$HTML_OUT_DIR"/*/"$class.php.html"
                )
            done
        fi
    fi

    if [[ ${#HTML_TO_OPEN[@]} -gt 0 ]]; then
        read -p 'Open HTML coverage report? [y/N]' open_cov
        if [[ $open_cov =~ ^[Yy] ]]; then
            for html in "${HTML_TO_OPEN[@]}"; do
                if [[ -f $html ]]; then
                    google-chrome "$html" &
                fi
            done
        fi
    fi
fi
