#!/bin/bash

ARGS=()
EXTRA_ARGS=()
EXCLUDE_PROJECTS=(
    # projects we're willfully ignorant of
    activecollab
    cert-manager
    ci-awscli
    ci-jshint
    ci-php-git
    ci-phpcs
    ci-phpunit
    ci-syncdns
    kserve
    linux_server_setup
    log-uploader
    make_sync
    pgdiff
    submodule-merger
    unit-testing-workshop

    # really old projects (>5 years)
    citrix-synergyanaheim2013
    intelcalendar
)
for arg in "$@"; do
    if [[ $arg = --no-tests ]]; then
        # because this is a fuckin pain to type
        EXTRA_ARGS+=(':(exclude)**/tests/*')
    elif [[ $arg = --all ]]; then
        # ignore garbage projects
        EXCLUDE_PROJECTS=()
    else
        ARGS+=("$arg")
    fi
done

for ex_proj in "${EXCLUDE_PROJECTS[@]}"; do
    EXTRA_ARGS+=(":(exclude)$ex_proj")
done

cd ~/g2git/__all_projects__ &&
exec ionice -c 3 -t git grep --heading --cached --recurse-submodules "${ARGS[@]}" "${EXTRA_ARGS[@]}"
