#!/bin/bash

VERSION=1
CACHE_DIR=~/.cache/yarn/yi-$VERSION

yarn_precomputed_cache() {
    if [[ -e yarn.lock ]]; then
        printf '%s/yarn-node_modules-%s' "$CACHE_DIR" $(sha256sum yarn.lock |cut -f 1 -d ' ')
    fi
}

# 1. yarn.lock does not exist
# -> install locally, then copy to cache
# 2. yarn.lock exists, but the cache does not
# -> install directly into cache, then link locally

run_yarn() (
    MYCACHE=$(yarn_precomputed_cache)
    if [[ -n $MYCACHE ]]; then
        rmdir -p -- "$MYCACHE" >/dev/null 2>&1
        if [[ -d $MYCACHE ]]; then
            printf 'yi: Found precomputed node_modules in %s\n' "$MYCACHE" >&2
            rm -rf node_modules &&
            cp -al -- "$MYCACHE" node_modules || exit
        fi
    fi
    YARN_MUTEXDIR=/tmp/yarn--$UID-mutexes
    YARN_MUTEX=$YARN_MUTEXDIR/${PWD//\//%%}-mutex
    YARN_ARGS=(
        --link-duplicates
        --prefer-offline
        --mutex "file:$YARN_MUTEX"
        "$@"
    )
    # yarn is SOOOO stupid!
    mkdir -p "$YARN_MUTEXDIR"
    if [[ -n $MYCACHE ]]; then
        # (sic; must go after user args)
        YARN_ARGS+=(--modules-folder "$MYCACHE")
    fi
    yarn install \
        "${YARN_ARGS[@]}" || exit
    if [[ -z $MYCACHE ]]; then
        # yarn.lock was generated
        # -> files are installed locally, need to be sent to cache
        MYCACHE=$(yarn_precomputed_cache)
        if [[ -z $MYCACHE ]]; then
            printf 'Failed to compute cache directory\n' >&2
            exit 2
        fi
        if [[ -d $MYCACHE ]]; then
            rm -rf -- "$MYCACHE"
            if [[ -d $MYCACHE ]]; then
                printf 'Failed to remove %s\n' "$MYCACHE" >&2
                exit 2
            fi
        fi
        cp -al -- node_modules "$MYCACHE" || exit
    else
        if [[ ! -d $MYCACHE ]]; then
            printf 'yarn failed to generate directory %s\n' "$MYCACHE" >&2
            exit 2
        fi
        # yarn.lock existed
        # -> files were installed into cache
        rm -rf node_modules &&
        cp -al -- "$MYCACHE" node_modules || exit
    fi
)

run_pnpm() {
    pnpm i --prefer-frozen-lockfile "$@"
}

collapse_yarn_cache() {
    # save some space by hard-linking files
    local SCAN_DIRS=(
        node_modules/
        ~/.cache/yarn/v?/
        ~/.cache/yarn/_extra_/
    )
    local EXTENSION_REGEX=(
        1
        DS_Store
        Makefile
        StyleCop
        ac
        am
        apk
        aspx
        babelrc
        bash_completion\\.in
        bat
        bazel
        bnf
        bowerrc
        c
        coffee
        cpp
        css
        def
        dtd
        editorconfig
        el
        eot
        eshintignore
        eslintignore
        eslintrc
        gif
        gitattributes
        gitignore
        gitmodules
        gyp
        h
        hpp
        ico
        iml
        info
        jpe?g
        js
        js\\.flow
        jshintignore
        json5\?
        jst
        key
        lcov
        less
        ls
        m4
        mailmap
        map
        markdown
        md
        node
        npmignore
        nupkg
        nuspec
        nvmrc
        otf
        patch
        pc\\.in
        pem
        pl
        png
        priv
        pub
        py
        rb
        rc
        sass
        scss
        sh
        sln
        spec
        styl
        svg
        swf
        tar
        test
        tgz
        tmpl
        travis.yml
        ts
        ttf
        txt
        vcxproj
        watchr
        woff
        x?html
        xml
        xpi
        xsl
        ya?ml
    )
    local FILENAMES_REGEX=(
        AUTHORS
        CHANGELOG
        CONTRIBUTORS
        COPYING
        CREDITS
        Change[Ll]og
        DEPS
        Dockerfile
        INSTALL
        LICEN[CS]E
        License
        Makefile
        PKG-INFO
        README
        base64_utf8
        bootstrap
        branding
        ci-build-libsass
        ci-build-plugin
        ci-install-compiler
        ci-install-deps
        ci-report-coverage
        encoding-async
        gyp
        handlebars
        hyper-schema
        jsesc
        json-ref
        lessc
        license
        links
        marked
        ng
        parser
        pnpm-lock\\.yaml
        semver
        spec
        stylus
        tap-driver
        tap-runner
        uglifyjs
        which
        xdg-open
        yarn\\.lock
    )
    local MATCH_REGEX=$(
        IFS='|'
        printf '.*(\.(%s)|%s)' \
            "${EXTENSION_REGEX[*]}" \
            "${FILENAMES_REGEX[*]}"
    )

    simplify_static_dir.pl -f \
        -m "$MATCH_REGEX" \
        "${SCAN_DIRS[@]}"
}

if [[ -e pnpm-lock.yaml ]]; then
    run_pnpm
else
    run_yarn
fi &&
# update timestamp (yarn sometimes does this, but inconsistently)
if [[ -e node_modules/.yarn-integrity && -e yarn.lock && node_modules/.yarn-integrity -ot yarn.lock ]]; then
    touch node_modules/.yarn-integrity
fi || exit
