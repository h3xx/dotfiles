# muttrc-mime

# MIME settings

# note: text/enriched is an alternative standard for email

# automatically convert these types of files (based on ~/.mailcap) into text
# and insert as part of the mail body
auto_view \
	application/x-gzip application/x-bzip2 \
	text/html \
	application/pdf \
	text/rtf application/rtf \
	text/enriched \
	application/msword \
	text/calendar application/ics

# save text part for last
# rationale: elinks does a better job than outlook at formatting HTML mail
# messages
alternative_order text/enriched text/html text/plain

# perform content-based MIME type detection on attachments with the following
# MIME types
mime_lookup application/octet-stream

